      <aliases enabled='yes' />
      <column caption='Is fraud calculation' datatype='integer' name='[Calculation_0186931519823872]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [is_fraud] = 1 THEN 1 END' />
      </column>
      <column caption='Fraud rate%' datatype='real' default-format='p0.00%' name='[Calculation_0186931520176129]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;    IF [is_fraud] = 1 THEN 1 ELSE 0 END&#13;&#10;)&#13;&#10;/&#13;&#10;COUNT([trans_num])' />
      </column>
      <column caption='Inflation-Adjusted Transaction Amounts' datatype='real' name='[Calculation_0889537335918592]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[amt] * (1 + 0.02) ^ (YEAR(TODAY()) - YEAR([trans_date_trans_time]))' />
      </column>
